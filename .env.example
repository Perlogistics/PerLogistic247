# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/supply_chain
REDIS_URL=redis://localhost:6379

# Stellar/Soroban Configuration
STELLAR_NETWORK=standalone
STELLAR_RPC_URL=http://localhost:8001
STELLAR_HORIZON_URL=http://localhost:8002

# Backend Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
RUST_LOG=debug

# Frontend Configuration
NEXT_PUBLIC_STELLAR_NETWORK=standalone
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_STELLAR_RPC_URL=http://localhost:8001

# Contract Addresses (set after deployment)
VISIBILITY_CONTRACT_ADDRESS=
ATTESTATION_CONTRACT_ADDRESS=
SETTLEMENT_CONTRACT_ADDRESS=

# Source Account for Contract Deployment
SOURCE_ACCOUNT=
